# Copy this to .env and fill in values
# cp .env.example .env

# ── App ───────────────────────────────────────────────────────────
APP_NAME=TaskFlow
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# ── Ports ─────────────────────────────────────────────────────────
NGINX_PORT=8000
FRONTEND_PORT=5173
DB_EXTERNAL_PORT=3307

# ── Database ──────────────────────────────────────────────────────
DB_DATABASE=taskflow
DB_USERNAME=taskflow
DB_PASSWORD=
DB_ROOT_PASSWORD=

# ── Redis ─────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── Frontend ──────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
